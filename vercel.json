{
  "regions": ["iad1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 15
    },
    "src/app/api/transcribe/route.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/birthday-eve",
      "schedule": "30 11 * * *"
    },
    {
      "path": "/api/cron/birthday-monthly",
      "schedule": "30 11 28-31 * *"
    },
    {
      "path": "/api/cron/session-reminder",
      "schedule": "0 3 * * 1"
    }
  ]
}
